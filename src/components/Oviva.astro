---
interface Props { t: typeof import('../locales/en.json') }
const { t } = Astro.props;
const o = t.oviva;
---

<section class="oviva-section">
  <div class="oviva-inner">
    <div class="oviva-content">
      <h2 class="font-heading-1 reveal-blur">{(o as { titleLine1?: string; titleLine2?: string }).titleLine1 ?? 'What is'}<br />{(o as { titleLine2?: string }).titleLine2 ?? 'Oviva Care'}</h2>
      <div class="font-body reveal" style="transition-delay: 0.15s">
        <p>{o.mission}</p>
        <p>{o.placeholder}</p>
      </div>
      <p class="font-heading-4 reveal" style="letter-spacing: 2.9px; text-transform: uppercase; margin: 0; transition-delay: 0.3s">{o.cta}</p>
    </div>
    <div class="oviva-image reveal-3d img-hover-zoom">
      <img class="parallax" data-speed="-0.06" src="https://www.figma.com/api/mcp/asset/db5b286a-d7b4-4eb5-94b3-4024bbc45282" alt="Support" loading="lazy" />
      <div class="oviva-image-overlay"></div>
      <span class="oviva-caption parallax" data-speed="0.12">support</span>
    </div>
  </div>
</section>

<style>
  .oviva-section { width: 100%; overflow: hidden; }
  .oviva-inner {
    max-width: 1512px; margin: 0 auto;
    display: flex; align-items: stretch; justify-content: space-between;
    padding: var(--spacing-80) 0; padding-left: var(--spacing-156);
  }
  .oviva-content { flex: 0 0 500px; display: flex; flex-direction: column; gap: var(--spacing-40); align-self: stretch; }
  .oviva-content h2 { margin: 0; }
  .oviva-content .font-body p { margin: 0 0 1em; }
  .oviva-image {
    flex: 0 0 743px; min-height: 710px;
    border-radius: var(--radius-32) 0 0 var(--radius-32);
    overflow: hidden; position: relative;
  }
  .oviva-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .oviva-image-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.7));
    border-radius: inherit; pointer-events: none;
  }
  .oviva-caption {
    position: absolute; bottom: 109px; left: 50%; transform: translateX(-50%);
    font-family: var(--font-body); font-size: 69px; font-weight: 700;
    color: var(--color-grey-white); text-transform: uppercase;
    letter-spacing: 6.9px; line-height: 1.3; white-space: nowrap;
    pointer-events: none;
  }
  @media (max-width: 768px) {
    .oviva-inner { flex-direction: column; padding-left: 16px; padding-right: 16px; gap: var(--spacing-32); }
    .oviva-content { flex: none; max-width: 100%; }
    .oviva-image { flex: none; width: 100%; height: 343px; min-height: unset; border-radius: var(--radius-32); }
    .oviva-caption { font-size: 32px; bottom: 40px; letter-spacing: 4px; }
  }
  @media (min-width: 769px) and (max-width: 1200px) {
    .oviva-inner { flex-direction: column; padding-left: var(--spacing-24); padding-right: var(--spacing-24); gap: var(--spacing-40); }
    .oviva-content { flex: none; max-width: 100%; }
    .oviva-image { flex: none; width: 100%; min-height: 400px; border-radius: var(--radius-32); }
    .oviva-caption { font-size: 40px; bottom: 60px; }
  }
</style>
