---
import ButtonPrimary from './Button/ButtonPrimary.astro';
interface Props { t: typeof import('../locales/en.json'); lang: string }
const { t, lang } = Astro.props;
const otherLang = lang === 'es' ? 'en' : 'es';
const otherLabel = lang === 'es' ? 'EN' : 'ES';
---

<header class="hero">
  <div class="hero-bg-wrap">
    <img class="hero-bg parallax" data-speed="-0.15" src="https://www.figma.com/api/mcp/asset/584a4666-d3ac-4f36-9714-616395f12e86" alt="" width="1512" height="982" />
  </div>
  <nav class="hero-nav">
    <a href={`/${lang}/`} class="hero-logo" aria-label="Oviva Care">
      <img src="https://www.figma.com/api/mcp/asset/ffd65b2d-b83b-4a72-b5f8-362ffc27b5ab" alt="Oviva Care" width="237" height="70" />
    </a>
    <a href={`/${otherLang}/`} class="lang-switch magnetic" aria-label={`Switch to ${otherLabel}`}>
      {otherLabel}
    </a>
  </nav>
  <div class="hero-card" id="hero-card">
    <p class="hero-question font-heading-6">{t.hero.question}</p>
    <div class="hero-card-title">
      <p class="hero-subtitle">{t.hero.joinLive}</p>
      <p class="hero-subtitle">{t.hero.webinarTitle}</p>
      <h1 class="font-heading-2">{t.hero.headline}</h1>
    </div>
    <div class="hero-cta">
      <p class="hero-date">{t.hero.date}</p>
      <ButtonPrimary href="#register" label={t.hero.saveSpot} />
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    height: 982px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: var(--spacing-80) var(--spacing-156);
    overflow: hidden;
  }
  .hero-bg-wrap {
    position: absolute;
    inset: -40px;
    overflow: hidden;
  }
  .hero-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    animation: heroBgZoom 2.5s var(--ease-out-expo) forwards;
    transform-origin: center center;
  }
  .hero-nav {
    position: absolute;
    top: 32px;
    left: var(--spacing-156);
    right: var(--spacing-156);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    animation: heroNavFade 1s var(--ease-out-expo) 0.3s both;
  }
  .hero-logo img { display: block; }
  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: background 0.3s ease, transform 0.3s var(--ease-spring);
  }
  .lang-switch:hover {
    background: rgba(255, 255, 255, 0.6);
    transform: scale(1.12);
  }
  .hero-card {
    position: relative;
    z-index: 2;
    max-width: 610px;
    padding: var(--spacing-56);
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: var(--radius-32);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-64);
    align-items: center;
    /* Start off-screen, animated via JS */
    opacity: 0;
    transform: translateX(-120px) scale(0.95);
    filter: blur(8px);
    animation: heroCardSlideIn 1.4s var(--ease-out-expo) 0.5s forwards;
  }
  .hero-question {
    margin: 0;
    color: var(--color-text-primary);
    text-align: center;
    font-weight: 700;
    line-height: 1.6;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .hero-card-title {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-24);
    text-align: center;
    color: var(--color-text-primary);
    width: 100%;
  }
  .hero-subtitle {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-heading-6-size);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1.6;
  }
  .hero-card-title h1 { margin: 0; }
  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
    align-items: center;
    width: 100%;
  }
  .hero-date {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-body-size);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    text-align: center;
    color: var(--color-text-primary);
  }
  @media (max-width: 768px) {
    .hero {
      height: 812px;
      padding: 0 16px 32px;
      align-items: flex-end;
      justify-content: center;
    }
    .hero-nav {
      left: 16px;
      right: 16px;
      top: 24px;
    }
    .hero-logo img {
      width: 48px;
      height: 48px;
      object-fit: contain;
      object-position: left;
    }
    .lang-switch {
      width: 36px;
      height: 36px;
      font-size: 12px;
    }
    .hero-card {
      max-width: 100%;
      padding: 32px 24px;
      gap: var(--spacing-32);
      border-radius: var(--radius-24);
    }
    .hero-question {
      font-size: 18px;
      letter-spacing: 1.5px;
    }
    .hero-card-title {
      gap: var(--spacing-16);
    }
    .hero-card-title h1 {
      font-size: 32px;
    }
    .hero-subtitle {
      font-size: 16px;
      letter-spacing: 1.5px;
    }
    .hero-date {
      font-size: 14px;
    }
  }
  @media (min-width: 769px) and (max-width: 1200px) {
    .hero { padding: var(--spacing-80) var(--spacing-24) var(--spacing-24); height: auto; min-height: 100vh; }
    .hero-nav { left: var(--spacing-24); right: var(--spacing-24); }
    .hero-card { max-width: 100%; }
  }
</style>
