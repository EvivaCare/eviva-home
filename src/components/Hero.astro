---
import ButtonPrimary from './Button/ButtonPrimary.astro';
import Navbar from './Navbar.astro';
interface Props { t: typeof import('../locales/en.json'); lang: string }
const { t, lang } = Astro.props;
---

<header class="hero">
  <div class="hero-bg-wrap">
    <img class="hero-bg parallax" data-speed="-0.15" src="https://www.figma.com/api/mcp/asset/584a4666-d3ac-4f36-9714-616395f12e86" alt="" width="1512" height="982" />
  </div>
  <Navbar t={t} lang={lang} activePage="home" />
  <div class="hero-card" id="hero-card">
    <p class="hero-question font-heading-6">{t.hero.question}</p>
    <div class="hero-card-title">
      <p class="hero-subtitle">{t.hero.joinLive}</p>
      <p class="hero-subtitle">{t.hero.webinarTitle}</p>
      <h1 class="font-heading-2">{t.hero.headline}</h1>
    </div>
    <div class="hero-cta">
      <p class="hero-date">{t.hero.date}</p>
      <ButtonPrimary href="#register" label={t.hero.saveSpot} />
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    height: 982px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: var(--spacing-80) var(--spacing-156);
    padding-top: 120px;
    overflow: hidden;
  }
  .hero-bg-wrap {
    position: absolute;
    inset: -40px;
    overflow: hidden;
  }
  .hero-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    animation: heroBgZoom 2.5s var(--ease-out-expo) forwards;
    transform-origin: center center;
  }
  .hero-card {
    position: relative;
    z-index: 2;
    max-width: 610px;
    padding: var(--spacing-56);
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: var(--radius-32);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-64);
    align-items: center;
    /* Start off-screen, animated via JS */
    opacity: 0;
    transform: translateX(-120px) scale(0.95);
    filter: blur(8px);
    animation: heroCardSlideIn 1.4s var(--ease-out-expo) 0.5s forwards;
  }
  .hero-question {
    margin: 0;
    color: var(--color-text-primary);
    text-align: center;
    font-weight: 700;
    line-height: 1.6;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .hero-card-title {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-24);
    text-align: center;
    color: var(--color-text-primary);
    width: 100%;
  }
  .hero-subtitle {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-heading-6-size);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1.6;
  }
  .hero-card-title h1 { margin: 0; }
  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
    align-items: center;
    width: 100%;
  }
  .hero-date {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-body-size);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    text-align: center;
    color: var(--color-text-primary);
  }
  @media (max-width: 768px) {
    .hero {
      height: 812px;
      padding: 0 16px 32px;
      align-items: flex-end;
      justify-content: center;
    }
    .hero-card {
      max-width: 100%;
      padding: 32px 24px;
      gap: var(--spacing-32);
      border-radius: var(--radius-24);
    }
    .hero-question {
      font-size: 18px;
      letter-spacing: 1.5px;
    }
    .hero-card-title {
      gap: var(--spacing-16);
    }
    .hero-card-title h1 {
      font-size: 32px;
    }
    .hero-subtitle {
      font-size: 16px;
      letter-spacing: 1.5px;
    }
    .hero-date {
      font-size: 14px;
    }
  }
  @media (min-width: 769px) and (max-width: 1200px) {
    .hero { padding: var(--spacing-80) var(--spacing-24) var(--spacing-24); height: auto; min-height: 100vh; }
    .hero-nav { left: var(--spacing-24); right: var(--spacing-24); }
    .hero-card { max-width: 100%; }
  }
</style>
