---
interface Props { t: typeof import('../../locales/en.json') }
const { t } = Astro.props;
---

<section class="symptoms section">
  <div class="symptoms-inner">
    <div class="symptoms-image-col">
      <div class="symptoms-image-wrap reveal-3d">
        <img
          src="https://www.figma.com/api/mcp/asset/183f9d43-7455-4902-aba5-ae6b4a3f1bdc"
          alt=""
          width="480"
          height="600"
          loading="lazy"
          class="symptoms-image"
        />
        <div class="symptoms-image-overlay"></div>
      </div>
      <div class="symptoms-float-badge reveal-scale" style="transition-delay: 0.4s" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="var(--color-brand-magenta)" stroke-width="2"/><path d="M12 8V12M12 16H12.01" stroke="var(--color-brand-magenta)" stroke-width="2" stroke-linecap="round"/></svg>
      </div>
    </div>
    <div class="symptoms-content-col">
      <h2 class="symptoms-title reveal-blur">{t.aboutSymptoms.title}</h2>
      <p class="symptoms-intro reveal" style="transition-delay: 0.1s">{t.aboutSymptoms.intro}</p>
      <ul class="symptoms-list">
        {t.aboutSymptoms.items.map((item: string, i: number) => (
          <li class="symptoms-item reveal-left" style={`transition-delay: ${0.1 + i * 0.08}s`}>
            <span class="symptoms-check" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="11" fill="var(--color-orange-10)"/><path d="M6.5 11.5L9.5 14.5L15.5 8" stroke="var(--color-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .symptoms {
    padding-top: var(--spacing-128);
    padding-bottom: var(--spacing-128);
    background: var(--color-bg-page);
  }
  .symptoms-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-80);
    align-items: center;
  }
  .symptoms-image-col {
    position: relative;
  }
  .symptoms-image-wrap {
    position: relative;
    border-radius: var(--radius-32);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
  }
  .symptoms-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  .symptoms-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(166, 3, 93, 0.06) 100%);
    pointer-events: none;
  }
  .symptoms-float-badge {
    position: absolute;
    bottom: 24px;
    right: -20px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: white;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: floatY 5s ease-in-out infinite;
    z-index: 2;
  }
  .symptoms-content-col {
    display: flex;
    flex-direction: column;
  }
  .symptoms-title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 3.5vw, 41px);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-16);
  }
  .symptoms-intro {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.1vw, 17px);
    line-height: 1.7;
    color: var(--color-grey-700);
    margin: 0 0 var(--spacing-32);
  }
  .symptoms-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .symptoms-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-16);
    font-family: var(--font-body);
    font-size: clamp(15px, 1.1vw, 17px);
    line-height: 1.6;
    color: var(--color-grey-700);
    padding: 14px var(--spacing-24);
    background: rgba(246, 142, 61, 0.03);
    border-radius: var(--radius-24);
    border: 1px solid rgba(246, 142, 61, 0.06);
    transition: transform 0.3s var(--ease-out-expo), box-shadow 0.3s ease, background 0.3s ease;
  }
  .symptoms-item:hover {
    transform: translateX(8px);
    box-shadow: 0 6px 24px rgba(246, 142, 61, 0.1);
    background: rgba(246, 142, 61, 0.06);
  }
  .symptoms-check {
    flex-shrink: 0;
    display: flex;
  }

  @media (max-width: 768px) {
    .symptoms {
      padding-top: var(--spacing-64);
      padding-bottom: var(--spacing-64);
    }
    .symptoms-inner {
      grid-template-columns: 1fr;
      gap: var(--spacing-32);
    }
    .symptoms-image-col {
      max-width: 320px;
      margin: 0 auto;
    }
    .symptoms-float-badge {
      right: -10px;
      bottom: 16px;
      width: 44px;
      height: 44px;
    }
    .symptoms-item {
      padding: 12px 16px;
    }
  }
  @media (min-width: 769px) and (max-width: 1200px) {
    .symptoms-inner {
      gap: var(--spacing-40);
    }
  }
</style>
