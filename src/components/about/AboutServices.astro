---
import ButtonPrimary from '../Button/ButtonPrimary.astro';
interface Props { t: typeof import('../../locales/en.json') }
const { t } = Astro.props;
---

<section class="services section" id="services">
  <h2 class="services-title reveal-blur">{t.aboutServices.title}</h2>

  <!-- Integrative Therapy Intro -->
  <div class="services-intro reveal" style="transition-delay: 0.1s">
    <h3 class="services-intro-title">{t.aboutServices.therapyTitle}</h3>
    <p class="services-intro-subtitle">{t.aboutServices.therapySubtitle}</p>
    <p class="services-intro-desc">{t.aboutServices.therapyDescription}</p>
  </div>

  <!-- What's included -->
  <div class="services-includes reveal" style="transition-delay: 0.15s">
    <h4 class="includes-title">{t.aboutServices.therapyIncludes}</h4>
    <ul class="includes-list">
      {t.aboutServices.therapyItems.map((item: string) => (
        <li class="includes-item">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="9" fill="var(--color-orange-10)"/><path d="M5.5 9.5L8 12L13 6.5" stroke="var(--color-orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {item}
        </li>
      ))}
    </ul>
    <p class="includes-note">{t.aboutServices.therapyNote}</p>
  </div>

  <!-- Pricing Cards -->
  <div class="pricing-grid">
    <!-- Single Session -->
    <div class="pricing-card reveal-scale" style="transition-delay: 0.1s">
      <div class="pricing-card-header">
        <h4 class="pricing-card-title">{t.aboutServices.singleTitle}</h4>
        <span class="pricing-card-duration">{t.aboutServices.singleDuration}</span>
      </div>
      <div class="pricing-card-price">
        <span class="price-amount">{t.aboutServices.singlePrice}</span>
      </div>
      <p class="pricing-card-note">{t.aboutServices.singleNote}</p>
    </div>

    <!-- Monthly (FEATURED) -->
    <div class="pricing-card pricing-card--featured reveal-scale" style="transition-delay: 0.2s">
      <span class="pricing-badge">{t.aboutServices.recommended}</span>
      <div class="pricing-card-glow" aria-hidden="true"></div>
      <div class="pricing-card-header">
        <h4 class="pricing-card-title">{t.aboutServices.monthlyTitle}</h4>
        <span class="pricing-card-duration">{t.aboutServices.monthlyPer}</span>
      </div>
      <div class="pricing-card-price">
        <span class="price-amount">{t.aboutServices.monthlyPrice}</span>
      </div>
      <ul class="pricing-card-includes">
        {t.aboutServices.monthlyIncludes.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>
      <ButtonPrimary href="#" label={t.aboutServices.quarterlyCta} />
    </div>

    <!-- 3-Month -->
    <div class="pricing-card reveal-scale" style="transition-delay: 0.3s">
      <div class="pricing-card-header">
        <h4 class="pricing-card-title">{t.aboutServices.quarterlyTitle}</h4>
        <span class="pricing-card-duration">{t.aboutServices.quarterlyPer}</span>
      </div>
      <div class="pricing-card-price">
        <span class="price-amount">{t.aboutServices.quarterlyPrice}</span>
      </div>
      <ul class="pricing-card-includes">
        {t.aboutServices.quarterlyIncludes.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>
      <p class="pricing-card-featured-note">{t.aboutServices.quarterlyNote}</p>
    </div>
  </div>

  <!-- Lab Review -->
  <div class="lab-section">
    <div class="lab-card reveal" style="transition-delay: 0.1s">
      <div class="lab-content">
        <h3 class="lab-title">{t.aboutServices.labTitle}</h3>
        <p class="lab-subtitle">{t.aboutServices.labSubtitle}</p>
        <p class="lab-desc">{t.aboutServices.labDescription}</p>
        <ul class="lab-includes">
          {t.aboutServices.labIncludes.map((item: string) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="8" fill="var(--color-orange-10)"/><path d="M5 8.5L7 10.5L11.5 5.5" stroke="var(--color-orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="lab-pricing">
        <span class="lab-duration">{t.aboutServices.labDuration}</span>
        <span class="lab-price">{t.aboutServices.labPrice}</span>
      </div>
    </div>
  </div>

  <!-- Not sure CTA -->
  <div class="not-sure reveal" style="transition-delay: 0.1s">
    <div class="not-sure-bg" aria-hidden="true">
      <img
        src="https://www.figma.com/api/mcp/asset/584a4666-d3ac-4f36-9714-616395f12e86"
        alt=""
        width="640"
        height="400"
        loading="lazy"
      />
      <div class="not-sure-bg-overlay"></div>
    </div>
    <div class="not-sure-content">
      <h3 class="not-sure-title">{t.aboutServices.notSure}</h3>
      <p class="not-sure-desc">{t.aboutServices.notSureDescription}</p>
      <ButtonPrimary href="#" label={t.aboutServices.notSureCta} />
    </div>
  </div>
</section>

<style>
  .services {
    padding-top: var(--spacing-128);
    padding-bottom: var(--spacing-128);
    background: var(--color-bg-page);
  }
  .services-title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 3.5vw, 41px);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text-primary);
    text-align: center;
    margin: 0 0 var(--spacing-56);
  }

  /* Intro */
  .services-intro {
    max-width: 780px;
    margin: 0 auto var(--spacing-40);
    text-align: center;
  }
  .services-intro-title {
    font-family: var(--font-body);
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-8);
  }
  .services-intro-subtitle {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.1vw, 17px);
    color: var(--color-grey-700);
    line-height: 1.7;
    margin: 0 0 var(--spacing-16);
  }
  .services-intro-desc {
    font-family: var(--font-body);
    font-size: clamp(14px, 1vw, 16px);
    color: var(--color-grey-400);
    line-height: 1.7;
    margin: 0;
    font-style: italic;
  }

  /* Includes */
  .services-includes {
    max-width: 640px;
    margin: 0 auto var(--spacing-64);
    padding: var(--spacing-32);
    background: rgba(246, 142, 61, 0.03);
    border-radius: var(--radius-24);
    border: 1px solid rgba(246, 142, 61, 0.08);
  }
  .includes-title {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-16);
  }
  .includes-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--spacing-16);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .includes-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: clamp(14px, 1vw, 15px);
    color: var(--color-grey-700);
    line-height: 1.5;
  }
  .includes-item svg { flex-shrink: 0; }
  .includes-note {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-grey-400);
    font-style: italic;
    margin: 0;
  }

  /* Pricing Grid */
  .pricing-grid {
    max-width: 1200px;
    margin: 0 auto var(--spacing-80);
    display: grid;
    grid-template-columns: 1fr 1.3fr 1fr;
    gap: var(--spacing-24);
    align-items: start;
  }
  .pricing-card {
    padding: var(--spacing-32);
    border-radius: var(--radius-24);
    border: 1px solid var(--color-grey-200);
    background: var(--color-bg-page);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
    transition: transform 0.5s var(--ease-out-expo), box-shadow 0.5s ease;
    position: relative;
    overflow: hidden;
  }
  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
  }

  /* FEATURED - 1 Month */
  .pricing-card--featured {
    border-color: var(--color-brand-magenta);
    border-width: 2px;
    padding: var(--spacing-40) var(--spacing-32);
    background: linear-gradient(180deg, rgba(166, 3, 93, 0.03) 0%, white 40%);
    transform: scale(1.02);
    box-shadow: 0 12px 40px rgba(166, 3, 93, 0.1);
  }
  .pricing-card--featured:hover {
    transform: scale(1.02) translateY(-6px);
    box-shadow: 0 20px 60px rgba(166, 3, 93, 0.15);
  }
  .pricing-card-glow {
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 200px;
    background: radial-gradient(ellipse, rgba(166, 3, 93, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .pricing-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--color-brand-magenta), var(--color-brand-700));
    color: white;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 20px;
    border-radius: var(--radius-100);
    white-space: nowrap;
    box-shadow: 0 4px 12px rgba(166, 3, 93, 0.3);
  }
  .pricing-card-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .pricing-card-title {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.3vw, 20px);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }
  .pricing-card-duration {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-grey-400);
    letter-spacing: 0.5px;
  }
  .pricing-card-price {
    padding: var(--spacing-8) 0;
  }
  .price-amount {
    font-family: var(--font-heading);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .pricing-card--featured .price-amount {
    font-size: clamp(32px, 3.5vw, 48px);
    background: linear-gradient(135deg, var(--color-brand-magenta), var(--color-orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .pricing-card-note {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-grey-400);
    line-height: 1.5;
    margin: 0;
  }
  .pricing-card-includes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pricing-card-includes li {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-grey-700);
    line-height: 1.5;
    padding-left: 18px;
    position: relative;
  }
  .pricing-card-includes li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand-magenta);
    opacity: 0.5;
  }
  .pricing-card--featured .pricing-card-includes li::before {
    opacity: 1;
  }
  .pricing-card-featured-note {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-grey-400);
    line-height: 1.6;
    font-style: italic;
    margin: 0;
    padding-top: var(--spacing-8);
    border-top: 1px solid var(--color-grey-200);
  }

  /* Lab Section */
  .lab-section {
    max-width: 900px;
    margin: 0 auto var(--spacing-80);
  }
  .lab-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--spacing-40);
    padding: var(--spacing-40);
    border-radius: var(--radius-24);
    border: 1px solid var(--color-grey-200);
    background: var(--color-bg-page);
    align-items: start;
    transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s ease;
  }
  .lab-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
  }
  .lab-title {
    font-family: var(--font-body);
    font-size: clamp(18px, 1.5vw, 22px);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-8);
  }
  .lab-subtitle {
    font-family: var(--font-body);
    font-size: clamp(14px, 1vw, 16px);
    color: var(--color-grey-700);
    line-height: 1.6;
    font-weight: 600;
    margin: 0 0 var(--spacing-8);
  }
  .lab-desc {
    font-family: var(--font-body);
    font-size: clamp(14px, 1vw, 15px);
    color: var(--color-grey-400);
    line-height: 1.7;
    font-style: italic;
    margin: 0 0 var(--spacing-16);
  }
  .lab-includes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .lab-includes li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-grey-700);
    line-height: 1.5;
  }
  .lab-includes li svg { flex-shrink: 0; }
  .lab-pricing {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: var(--spacing-24);
    background: rgba(166, 3, 93, 0.03);
    border-radius: var(--radius-24);
    min-width: 160px;
  }
  .lab-duration {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-grey-400);
  }
  .lab-price {
    font-family: var(--font-heading);
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  /* Not Sure - with background image */
  .not-sure {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    border-radius: var(--radius-32);
    overflow: hidden;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .not-sure-bg {
    position: absolute;
    inset: 0;
  }
  .not-sure-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .not-sure-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(166, 3, 93, 0.88) 0%,
      rgba(130, 2, 74, 0.92) 50%,
      rgba(166, 3, 93, 0.85) 100%
    );
  }
  .not-sure-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-56);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-16);
  }
  .not-sure-title {
    font-family: var(--font-heading);
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 700;
    color: white;
    margin: 0;
  }
  .not-sure-desc {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.1vw, 17px);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    margin: 0;
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .services {
      padding-top: var(--spacing-64);
      padding-bottom: var(--spacing-64);
    }
    .pricing-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-16);
    }
    .pricing-card--featured {
      transform: none;
    }
    .pricing-card--featured:hover {
      transform: translateY(-6px);
    }
    .lab-card {
      grid-template-columns: 1fr;
      padding: var(--spacing-24);
    }
    .lab-pricing {
      flex-direction: row;
      justify-content: center;
      gap: var(--spacing-16);
    }
    .services-includes {
      padding: var(--spacing-24);
    }
    .not-sure-content {
      padding: var(--spacing-32);
    }
    .pricing-card {
      padding: var(--spacing-24);
    }
    .pricing-card--featured {
      padding: var(--spacing-32) var(--spacing-24);
    }
  }
  @media (min-width: 769px) and (max-width: 1200px) {
    .pricing-grid {
      grid-template-columns: 1fr 1fr;
    }
    .pricing-card--featured {
      grid-column: 1 / -1;
      max-width: 500px;
      margin: 0 auto;
      width: 100%;
    }
  }
</style>
