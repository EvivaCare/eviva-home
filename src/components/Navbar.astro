---
interface Props {
  t: typeof import('../locales/en.json');
  lang: string;
  activePage?: 'home' | 'about';
}
const { t, lang, activePage = 'home' } = Astro.props;
const otherLang = lang === 'es' ? 'en' : 'es';
const otherLabel = lang === 'es' ? 'EN' : 'ES';

const homeHref = lang === 'en' ? '/' : `/${lang}/`;
const aboutHref = `/${lang}/about`;
---

<nav class="navbar" id="navbar">
  <a href={homeHref} class="navbar-logo" aria-label="Oviva Care">
    <img src="https://www.figma.com/api/mcp/asset/ffd65b2d-b83b-4a72-b5f8-362ffc27b5ab" alt="Oviva Care" width="237" height="70" />
  </a>

  <div class="navbar-links">
    <a href={homeHref} class:list={['navbar-link', { active: activePage === 'home' }]}>{t.nav.home}</a>
    <a href={aboutHref} class:list={['navbar-link', { active: activePage === 'about' }]}>{t.nav.about}</a>
  </div>

  <div class="navbar-actions">
    <a href={`/${otherLang}/`} class="lang-switch magnetic" aria-label={`Switch to ${otherLabel}`}>
      {otherLabel}
    </a>
    <button class="navbar-burger" id="navbar-burger" aria-label={t.nav.menu} aria-expanded="false">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar-mobile" id="navbar-mobile">
    <a href={homeHref} class:list={['navbar-mobile-link', { active: activePage === 'home' }]}>{t.nav.home}</a>
    <a href={aboutHref} class:list={['navbar-mobile-link', { active: activePage === 'about' }]}>{t.nav.about}</a>
    <a href={`/${otherLang}/`} class="navbar-mobile-link">{otherLabel}</a>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px var(--spacing-156);
    transition: background 0.4s ease, box-shadow 0.4s ease, padding 0.4s ease;
    animation: heroNavFade 1s var(--ease-out-expo) 0.3s both;
  }
  .navbar.scrolled {
    background: rgba(250, 249, 250, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 30px rgba(0, 0, 0, 0.06);
    padding-top: 10px;
    padding-bottom: 10px;
  }
  .navbar-logo img {
    display: block;
    height: 50px;
    width: auto;
    transition: height 0.4s ease;
  }
  .navbar.scrolled .navbar-logo img {
    height: 40px;
  }
  .navbar-links {
    display: flex;
    gap: var(--spacing-32);
    align-items: center;
  }
  .navbar-link {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-primary);
    position: relative;
    padding: 4px 0;
    transition: color 0.3s ease;
  }
  .navbar-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-brand-magenta);
    transition: width 0.4s var(--ease-out-expo);
  }
  .navbar-link:hover::after,
  .navbar-link.active::after {
    width: 100%;
  }
  .navbar-link.active {
    color: var(--color-brand-magenta);
  }
  .navbar-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-16);
  }
  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(166, 3, 93, 0.08);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: background 0.3s ease, transform 0.3s var(--ease-spring);
  }
  .lang-switch:hover {
    background: rgba(166, 3, 93, 0.15);
    transform: scale(1.08);
  }
  .navbar-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .burger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .navbar-burger.open .burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .navbar-burger.open .burger-line:nth-child(2) {
    opacity: 0;
  }
  .navbar-burger.open .burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .navbar-mobile {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: rgba(250, 249, 250, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    flex-direction: column;
    padding: var(--spacing-24) var(--spacing-32);
    gap: var(--spacing-16);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }
  .navbar-mobile.open {
    display: flex;
  }
  .navbar-mobile-link {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-primary);
    padding: var(--spacing-8) 0;
    transition: color 0.3s ease;
  }
  .navbar-mobile-link.active {
    color: var(--color-brand-magenta);
  }
  .navbar-mobile-link:hover {
    color: var(--color-brand-magenta);
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 12px 16px;
    }
    .navbar-links {
      display: none;
    }
    .navbar-burger {
      display: flex;
    }
    .navbar-logo img {
      height: 40px;
    }
    .navbar.scrolled .navbar-logo img {
      height: 36px;
    }
    .lang-switch {
      width: 36px;
      height: 36px;
      font-size: 12px;
    }
  }
  @media (min-width: 769px) and (max-width: 1200px) {
    .navbar {
      padding: 14px var(--spacing-24);
    }
  }
</style>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  if (navbar) {
    const handleScroll = () => {
      if (window.scrollY > 60) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  }

  // Mobile menu toggle
  const burger = document.getElementById('navbar-burger');
  const mobile = document.getElementById('navbar-mobile');
  if (burger && mobile) {
    burger.addEventListener('click', () => {
      const isOpen = burger.classList.toggle('open');
      mobile.classList.toggle('open');
      burger.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>
