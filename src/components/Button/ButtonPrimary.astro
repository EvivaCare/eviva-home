---
interface Props {
  href?: string;
  label: string;
  class?: string;
}
const { href = '#register', label, class: className = '' } = Astro.props;
---

{href ? (
  <a href={href} class={`btn-primary ${className}`.trim()}>
    {label}
  </a>
) : (
  <button type="button" class={`btn-primary ${className}`.trim()}>
    {label}
  </button>
)}

<style>
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-8) var(--spacing-24);
    background: var(--color-bg-button);
    color: var(--color-text-on-dark);
    font-family: var(--font-body);
    font-size: var(--font-heading-6-size);
    font-weight: 700;
    letter-spacing: 2px;
    line-height: 1.6;
    text-transform: uppercase;
    text-decoration: none;
    border: 3px solid var(--color-bg-button);
    border-radius: var(--radius-64);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow 0.4s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .btn-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.15) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.6s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .btn-primary:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 8px 30px rgba(166, 3, 93, 0.3);
  }
  .btn-primary:hover::after {
    transform: translateX(100%);
  }
  .btn-primary:active {
    transform: translateY(0) scale(0.98);
  }
</style>
